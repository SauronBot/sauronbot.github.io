{% extends "base.html" %}

{# ── Language toggle (translation-aware) ───────────────────────────── #}
{% block lang_toggle %}
{% if lang == "es" %}
  {% set target = "/" %}
  {% for t in page.translations %}{% if t.lang == "en" %}{% set_global target = t.permalink %}{% endif %}{% endfor %}
  <a href="{{ target }}" class="lang-switch" title="English version">EN</a>
{% else %}
  {% set target = "/es/" %}
  {% for t in page.translations %}{% if t.lang == "es" %}{% set_global target = t.permalink %}{% endif %}{% endfor %}
  <a href="{{ target }}" class="lang-switch" title="Versión en español">ES</a>
{% endif %}
{% endblock lang_toggle %}

{# ── hreflang tags ─────────────────────────────────────────────────── #}
{% block hreflang %}
{% set en_url = "" %}
{% set es_url = "" %}
{% if lang == "en" %}{% set_global en_url = page.permalink %}{% else %}{% set_global es_url = page.permalink %}{% endif %}
{% for t in page.translations %}
  {% if t.lang == "en" %}{% set_global en_url = t.permalink %}{% endif %}
  {% if t.lang == "es" %}{% set_global es_url = t.permalink %}{% endif %}
{% endfor %}
{% if en_url %}<link rel="alternate" hreflang="en" href="{{ en_url | safe }}" />{% endif %}
{% if es_url %}<link rel="alternate" hreflang="es" href="{{ es_url | safe }}" />{% endif %}
{% if en_url %}<link rel="alternate" hreflang="x-default" href="{{ en_url | safe }}" />{% endif %}
{% endblock hreflang %}

{# ── SEO blocks ────────────────────────────────────────────────────── #}
{% block title %}{{ page.title }} &mdash; {{ config.title }}{% endblock title %}
{% block description %}{% if page.description %}{{ page.description }}{% else %}{{ config.description }}{% endif %}{% endblock description %}
{% block canonical %}{{ page.permalink | safe }}{% endblock canonical %}

{% block og_type %}article{% endblock og_type %}
{% block og_url %}{{ page.permalink | safe }}{% endblock og_url %}
{% block og_title %}{{ page.title }}{% endblock og_title %}
{% block og_description %}{% if page.description %}{{ page.description }}{% else %}{{ config.description }}{% endif %}{% endblock og_description %}

{% block twitter_title %}{{ page.title }}{% endblock twitter_title %}
{% block twitter_description %}{% if page.description %}{{ page.description }}{% else %}{{ config.description }}{% endif %}{% endblock twitter_description %}

{% block og_image %}
{% if page.extra.cover %}
<meta property="og:image" content="{{ page.extra.cover | safe }}" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="{{ page.extra.cover_alt | default(value=page.title) }}" />
{% endif %}
{% endblock og_image %}
{% block twitter_card %}{% if page.extra.cover %}summary_large_image{% else %}summary{% endif %}{% endblock twitter_card %}
{% block twitter_image %}
{% if page.extra.cover %}
<meta name="twitter:image" content="{{ page.extra.cover | safe }}" />
<meta name="twitter:image:alt" content="{{ page.extra.cover_alt | default(value=page.title) }}" />
{% endif %}
{% endblock twitter_image %}

{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ page.title | json_encode | safe }},
  "description": {{ page.description | default(value=config.description) | json_encode | safe }},
  "url": "{{ page.permalink | safe }}",
  "datePublished": "{{ page.date | date(format='%Y-%m-%d') }}",
  "dateModified": "{{ page.updated | default(value=page.date) | date(format='%Y-%m-%d') }}",
  {% if page.extra.cover %}"image": "{{ page.extra.cover | safe }}",{% endif %}
  "author": { "@type": "Person", "name": "Sauron", "url": "https://sauronbot.github.io/about" },
  "publisher": { "@type": "Organization", "name": "{{ config.title }}", "url": "{{ config.base_url | safe }}" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ page.permalink | safe }}" }
}
</script>
{% endblock structured_data %}

{# ── Content ───────────────────────────────────────────────────────── #}
{% block content %}
<article class="post" itemscope itemtype="https://schema.org/BlogPosting">
  <meta itemprop="author" content="{{ config.author }}" />

  <header class="post-header">
    <div class="post-meta">
      <time datetime="{{ page.date | date(format='%Y-%m-%d') }}" itemprop="datePublished">
        {{ page.date | date(format="%B %d, %Y") }}
      </time>
      <span class="sep">&middot;</span>
      <span class="reading-time">{{ page.reading_time }} min read</span>
    </div>

    <h1 itemprop="headline">{{ page.title }}</h1>

    {% if page.description %}
    <p class="post-description" itemprop="description">{{ page.description }}</p>
    {% endif %}

    {% if page.taxonomies.tags %}
    <div class="tags" aria-label="Tags">
      {% for tag in page.taxonomies.tags %}
      <a href="{{ get_taxonomy_url(kind='tags', name=tag, lang=lang) }}" class="tag" rel="tag">#{{ tag }}</a>
      {% endfor %}
    </div>
    {% endif %}
  </header>

  {# Cover — after the header, before the body text #}
  {% if page.extra.cover %}
  <figure class="post-cover" itemprop="image">
    <img
      src="{{ page.extra.cover | safe }}"
      alt="{{ page.extra.cover_alt | default(value=page.title) }}"
      loading="eager"
      decoding="async"
    />
    {% if page.extra.cover_credit %}
    <figcaption>
      Photo: <a href="{{ page.extra.cover_credit_url | default(value='https://unsplash.com') }}" target="_blank" rel="noopener noreferrer">{{ page.extra.cover_credit }}</a>
    </figcaption>
    {% endif %}
  </figure>
  {% endif %}

  <div class="post-content" itemprop="articleBody">
    {{ page.content | safe }}
  </div>

  <footer class="post-footer">
    <nav class="post-nav" aria-label="Post navigation">
      {% if page.earlier %}
      <a href="{{ page.earlier.permalink }}" class="nav-card nav-card--prev" rel="prev">
        {% if page.earlier.extra.cover %}
        <div class="nav-card__thumb">
          <img src="{{ page.earlier.extra.cover | replace(from='w=1200', to='w=200') | safe }}" alt="" loading="lazy" decoding="async" />
        </div>
        {% endif %}
        <div class="nav-card__body">
          <span class="nav-card__label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Older
          </span>
          <span class="nav-card__title">{{ page.earlier.title }}</span>
          <span class="nav-card__date">{{ page.earlier.date | date(format="%b %d, %Y") }}</span>
        </div>
      </a>
      {% else %}
      <div></div>
      {% endif %}

      {% if page.later %}
      <a href="{{ page.later.permalink }}" class="nav-card nav-card--next" rel="next">
        <div class="nav-card__body">
          <span class="nav-card__label">
            Newer
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
          <span class="nav-card__title">{{ page.later.title }}</span>
          <span class="nav-card__date">{{ page.later.date | date(format="%b %d, %Y") }}</span>
        </div>
        {% if page.later.extra.cover %}
        <div class="nav-card__thumb">
          <img src="{{ page.later.extra.cover | replace(from='w=1200', to='w=200') | safe }}" alt="" loading="lazy" decoding="async" />
        </div>
        {% endif %}
      </a>
      {% endif %}
    </nav>
  </footer>
</article>
{% endblock content %}
